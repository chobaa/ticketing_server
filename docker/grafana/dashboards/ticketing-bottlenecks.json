{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ticketing", "bottleneck"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "티켓팅 병목 추적 (원인 분해)",
  "uid": "ticketing-bottlenecks",
  "version": 2,
  "description": "앱·exporter에서 실제 수집되는 지표만 표시합니다.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kafka up (앱 ping)",
      "description": "ticketing_kafka_up — AdminClient describeCluster",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "max(ticketing_kafka_up{job=\"ticketing\"})" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1, "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Redis up (앱 ping)",
      "description": "ticketing_redis_up — Redis PING",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "max(ticketing_redis_up{job=\"ticketing\"})" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1, "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "결제 큐 깊이 (Rabbit)",
      "description": "ticketing_payment_queue_depth — payment.queue 메시지 수(앱이 직접 조회)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "max(ticketing_payment_queue_depth{job=\"ticketing\"})" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "대기열 인원 (OPEN 이벤트)",
      "description": "ticketing_waiting_queue_size — Redis 대기열 합",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "max(ticketing_waiting_queue_size{job=\"ticketing\"})" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka consumer lag (exporter)",
      "description": "kafka-exporter. 컨슈머가 없거나 lag=0이면 0에 가깝게 보입니다.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "lag(total)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "결제 파이프라인 (앱)",
      "description": "inflight = requested − (succeeded+failed). rate는 Kafka→Rabbit→정산 처리량.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(ticketing_payment_inflight{job=\"ticketing\"})",
          "legendFormat": "inflight"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ticketing_payment_requested_total{job=\"ticketing\"}[1m]))",
          "legendFormat": "requested/s"
        },
        {
          "refId": "C",
          "expr": "sum(rate(ticketing_payment_succeeded_total{job=\"ticketing\"}[1m]))",
          "legendFormat": "succeeded/s"
        },
        {
          "refId": "D",
          "expr": "sum(rate(ticketing_payment_failed_total{job=\"ticketing\"}[1m]))",
          "legendFormat": "failed/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "MySQL connections (exporter)",
      "description": "mysqld-exporter threads_connected",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "mysql_global_status_threads_connected or on() mysql_global_status{status=\"Threads_connected\"}",
          "legendFormat": "threads_connected"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis memory (exporter, cluster 합)",
      "description": "redis-exporter 6노드 합산 used_bytes",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(redis_memory_used_bytes)",
          "legendFormat": "used_bytes"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HikariCP (DB pool)",
      "description": "active/pending — pending>0이면 DB 커넥션 고갈 의심",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(hikaricp_connections_active{job=\"ticketing\"})",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "sum(hikaricp_connections_pending{job=\"ticketing\"})",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    }
  ]
}
