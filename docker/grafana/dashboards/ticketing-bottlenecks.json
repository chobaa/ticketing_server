{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ticketing", "bottleneck"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "티켓팅 병목 추적 (원인 분해)",
  "uid": "ticketing-bottlenecks",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kafka up (app 관점)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [{ "refId": "A", "expr": "sum(ticketing_kafka_up)" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Redis up (app 관점)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "targets": [{ "refId": "A", "expr": "sum(ticketing_redis_up)" }],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RabbitMQ payment.queue depth",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "targets": [{ "refId": "A", "expr": "sum(rabbitmq_queue_messages{queue=\"payment.queue\"})" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Kafka consumer lag (exporter)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "lag(total)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "MySQL connections (exporter)",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mysql_global_status_threads_connected)",
          "legendFormat": "threads_connected"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis evictions / memory (exporter)",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(redis_evicted_keys_total[1m]))",
          "legendFormat": "evicted_keys/s"
        },
        {
          "refId": "B",
          "expr": "sum(redis_memory_used_bytes)",
          "legendFormat": "used_bytes"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [
        { "matcher": { "id": "byName", "options": "evicted_keys/s" }, "properties": [{ "id": "unit", "value": "ops" }] }
      ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    }
  ]
}

