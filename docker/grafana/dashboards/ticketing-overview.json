{
  "uid": "ticketing-overview",
  "title": "Ticketing Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["ticketing"],
  "panels": [
    {
      "type": "stat",
      "title": "Waiting queue size (OPEN events)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "ticketing_waiting_queue_size"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Redis up (PING)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "ticketing_redis_up"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RabbitMQ connections",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "rabbitmq_connections"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Kafka consumer lag (max)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(kafka_consumer_fetch_manager_records_lag_max)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests / sec (all)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"ticketing\"}[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error rate (4xx + 5xx) / sec",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"ticketing\",status=~\"4..|5..\"}[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (seconds)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"ticketing\"}[1m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka incoming bytes / sec (sum)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kafka_consumer_incoming_byte_total[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ published / sec",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rabbitmq_published_total[1m]))"
        }
      ]
    }
  ]
}

