{
  "uid": "ticketing-overview",
  "title": "티켓팅 핵심 대시보드",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "5s",
  "tags": ["ticketing"],
  "panels": [
    {
      "type": "stat",
      "title": "데이터 정합성 불일치(합계)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_integrity_mismatch_held_vs_pending) + sum(ticketing_integrity_mismatch_sold_vs_confirmed) + sum(ticketing_integrity_mismatch_confirmed_vs_payment_success) + sum(ticketing_integrity_mismatch_canceled_vs_payment_failed)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "발행 - (성공+실패) 차이(구간)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "((round(sum(increase(ticketing_messaging_kafka_produced_total{topic=\"payment-requested\"}[$__range])))) or vector(0)) - (round(sum(increase(ticketing_payment_succeeded_total[$__range]))) + round(sum(increase(ticketing_payment_failed_total[$__range]))))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "누적 처리량(성공+실패 총합)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_payment_succeeded_total) + sum(ticketing_payment_failed_total)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "평균 응답시간(ms)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_requests_seconds_sum{job=\"ticketing\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"ticketing\"}[1m]))) * 1000"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "성공(구간)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "round(sum(increase(ticketing_payment_succeeded_total[$__range])))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "실패(구간)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "round(sum(increase(ticketing_payment_failed_total[$__range])))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "timeseries",
      "title": "데이터 정합성 불일치(0이어야 정상)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(ticketing_integrity_mismatch_held_vs_pending)" },
        { "refId": "B", "expr": "sum(ticketing_integrity_mismatch_sold_vs_confirmed)" },
        { "refId": "C", "expr": "sum(ticketing_integrity_mismatch_confirmed_vs_payment_success)" },
        { "refId": "D", "expr": "sum(ticketing_integrity_mismatch_canceled_vs_payment_failed)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "발행 vs 정산(구간 누적)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "(round(sum(increase(ticketing_messaging_kafka_produced_total{topic=\"payment-requested\"}[$__range])))) or vector(0)", "legendFormat": "발행(issued)" },
        { "refId": "B", "expr": "round(sum(increase(ticketing_payment_succeeded_total[$__range]) + increase(ticketing_payment_failed_total[$__range])))", "legendFormat": "정산(settled)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "누적 처리량(성공+실패) — 기울기로 확인",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_payment_succeeded_total) + sum(ticketing_payment_failed_total)",
          "legendFormat": "누적 처리량"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "평균 응답시간(ms)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "(sum(rate(http_server_requests_seconds_sum{job=\"ticketing\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"ticketing\"}[1m]))) * 1000" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis 반응성(PING latency, ms)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "ticketing_redis_ping_latency_ms" }
      ]
    }
  ]
}

