{
  "uid": "ticketing-overview",
  "title": "티켓팅 핵심 대시보드",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 20,
  "refresh": "5s",
  "tags": ["ticketing"],
  "panels": [
    {
      "type": "stat",
      "title": "데이터 정합성 불일치(합계)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_integrity_mismatch_held_vs_pending) + sum(ticketing_integrity_mismatch_sold_vs_confirmed) + sum(ticketing_integrity_mismatch_confirmed_vs_payment_success) + sum(ticketing_integrity_mismatch_pending_vs_payment_processing)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "WIP = 발행 - (성공+실패+드롭+중복) (구간)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "((round(sum(increase(ticketing_payment_requested_total[$__range])))) or vector(0))\n - (\n   round(sum(increase(ticketing_payment_succeeded_total[$__range])))\n   + round(sum(increase(ticketing_payment_failed_total[$__range])))\n   + round(sum(increase(ticketing_payment_request_dropped_missing_reservation_total[$__range])))\n   + round(sum(increase(ticketing_payment_request_skipped_duplicate_total[$__range])))\n )"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "누적 처리량(성공+실패 총합)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_integrity_payments_success) + sum(ticketing_integrity_payments_failed)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "평균 응답시간(ms)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_requests_seconds_sum{job=\"ticketing\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"ticketing\"}[1m]))) * 1000"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "성공(구간)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "round(sum(increase(ticketing_payment_succeeded_total[$__range])))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "실패(구간)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "refId": "A", "expr": "round(sum(increase(ticketing_payment_failed_total[$__range])))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "드롭+중복(구간)",
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(ticketing_payment_request_dropped_missing_reservation_total[$__range])) + sum(increase(ticketing_payment_request_skipped_duplicate_total[$__range])))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "WIP(현재) = 발행 - (성공+실패+드롭+중복)",
      "gridPos": { "x": 4, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "round(\n  sum(ticketing_payment_requested_total)\n  - (\n    sum(ticketing_payment_succeeded_total)\n    + sum(ticketing_payment_failed_total)\n    + sum(ticketing_payment_request_dropped_missing_reservation_total)\n    + sum(ticketing_payment_request_skipped_duplicate_total)\n  )\n)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "결제 backlog(현재=대기+처리중)",
      "gridPos": { "x": 8, "y": 4, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rabbitmq_queue_messages{queue=\"payment.queue\"})"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "payment.queue consumed(구간 누적)",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(ticketing_messaging_rabbit_consumed_total{queue=\"payment.queue\"}[$__range])))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "payment.queue published(구간 누적)",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(ticketing_messaging_rabbit_published_total{queue=\"payment.queue\"}[$__range])))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "timeseries",
      "title": "데이터 정합성 불일치(0이어야 정상)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(ticketing_integrity_mismatch_held_vs_pending)" },
        { "refId": "B", "expr": "sum(ticketing_integrity_mismatch_sold_vs_confirmed)" },
        { "refId": "C", "expr": "sum(ticketing_integrity_mismatch_confirmed_vs_payment_success)" },
        { "refId": "D", "expr": "sum(ticketing_integrity_mismatch_pending_vs_payment_processing)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "발행 vs 정산(구간 누적)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "(round(sum(increase(ticketing_payment_requested_total[$__range])))) or vector(0)", "legendFormat": "requested(발행)" },
        { "refId": "B", "expr": "round(sum(increase(ticketing_integrity_payments_success[$__range]) + increase(ticketing_integrity_payments_failed[$__range])))", "legendFormat": "settled(DB,success+fail)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ payment.queue backlog(ready/unacked/total)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rabbitmq_queue_messages_ready{queue=\"payment.queue\"})", "legendFormat": "ready" },
        { "refId": "B", "expr": "sum(rabbitmq_queue_messages_unacked{queue=\"payment.queue\"})", "legendFormat": "unacked(in-flight)" },
        { "refId": "C", "expr": "sum(rabbitmq_queue_messages{queue=\"payment.queue\"})", "legendFormat": "total" },
        { "refId": "D", "expr": "sum(rabbitmq_queue_consumers{queue=\"payment.queue\"})", "legendFormat": "consumers" }
      ]
    },
    {
      "type": "timeseries",
      "title": "payment.queue 처리량(consume rate)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ticketing_messaging_rabbit_consumed_total{queue=\"payment.queue\"}[1m]))",
          "legendFormat": "consumed/sec"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ticketing_messaging_rabbit_published_total{queue=\"payment.queue\"}[1m]))",
          "legendFormat": "published/sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "결제 파이프라인: requested / settled / inflight",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(ticketing_payment_requested_total)", "legendFormat": "requested(issued_to_worker_queue,total)" },
        { "refId": "B", "expr": "sum(ticketing_integrity_payments_success) + sum(ticketing_integrity_payments_failed)", "legendFormat": "settled(DB,total)=success+fail" },
        { "refId": "C", "expr": "sum(ticketing_integrity_payments_processing)", "legendFormat": "worker_sleep(processing,current)" },
        { "refId": "D", "expr": "sum(rabbitmq_queue_messages_ready{queue=\"payment.queue\"})", "legendFormat": "queue_ready(rabbit,current)" },
        { "refId": "H", "expr": "sum(rabbitmq_queue_messages_unacked{queue=\"payment.queue\"})", "legendFormat": "queue_unacked(rabbit,current)" },
        { "refId": "E", "expr": "sum(ticketing_payment_request_skipped_duplicate_total)", "legendFormat": "skipped(duplicate,total)" },
        { "refId": "F", "expr": "sum(ticketing_payment_request_dropped_missing_reservation_total)", "legendFormat": "dropped(missing_reservation,total)" },
        { "refId": "G", "expr": "sum(ticketing_payment_settle_skipped_already_terminal_total)", "legendFormat": "skipped(settle_already_terminal,total)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "누적 처리량(성공+실패) — 기울기로 확인",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ticketing_integrity_payments_success) + sum(ticketing_integrity_payments_failed)",
          "legendFormat": "누적 처리량"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "평균 응답시간(ms)",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "(sum(rate(http_server_requests_seconds_sum{job=\"ticketing\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"ticketing\"}[1m]))) * 1000" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis 반응성(PING latency, ms)",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "ticketing_redis_ping_latency_ms" }
      ]
    }
  ]
}

